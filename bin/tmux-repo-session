#!/bin/sh

set -eu

detach=false

if [ "${1:-}" = "--detach" ]; then
  detach=true
  shift
fi

name=${1:?session name is required}
path=${2:?path is required}

if [ ! -d "$path" ]; then
  tmux display-message "Missing repo: $path"
  exit 1
fi

ensure_window () {
  local session=$1
  local window=$2
  local cwd=$3

  if tmux list-windows -t "$session" -F '#{window_name}' 2>/dev/null | grep -qx "$window"
  then
    return
  fi

  tmux new-window -t "$session" -n "$window" -c "$cwd" >/dev/null
}

if ! tmux has-session -t "$name" 2>/dev/null
then
  tmux new-session -d -s "$name" -c "$path" -n editor
  ensure_window "$name" logs "$path"
  ensure_window "$name" db "$path"
else
  ensure_window "$name" editor "$path"
  ensure_window "$name" logs "$path"
  ensure_window "$name" db "$path"
fi

if [ "$detach" = "true" ]; then
  exit 0
fi

exec tmux switch-client -t "$name"
